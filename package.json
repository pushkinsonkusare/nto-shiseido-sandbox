{
  "name": "nto-shiseido-sandbox",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bash scripts/dev-watch.sh",
    "dev:once": "node --max-old-space-size=8192 ./node_modules/vite/bin/vite.js",
    "dev:fresh": "bash scripts/dev-fresh.sh",
    "dev:stop": "bash scripts/dev-stop.sh",
    "kill:dev": "lsof -ti tcp:5173 | xargs -r kill -9 2>/dev/null; exit 0",
    "eval:activities": "npx vite-node scripts/evaluate-activity-recommendations.ts",
    "build": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js build",
    "postbuild": "touch docs/.nojekyll && cp docs/index.html docs/404.html",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/papaparse": "^5.5.2",
    "lucide-react": "^1.14.0",
    "openai": "^6.34.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.7",
    "@types/react-dom": "^18.3.2",
    "@vitejs/plugin-react": "^4.3.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
